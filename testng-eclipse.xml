<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Hybrid Automation Test Suite" parallel="tests" thread-count="2">
    
    <!-- API Automation Tests - Run via Maven -->
    <test name="API Automation Tests">
        <groups>
            <run>
                <include name="api"/>
            </run>
        </groups>
        <classes>
            <class name="com.framework.api.stepdefinitions.TC1_GetAllProductsSteps"/>
            <class name="com.framework.api.stepdefinitions.TC2_GetSingleProductSteps"/>
            <class name="com.framework.api.stepdefinitions.TC3_CreateUserSteps"/>
            <class name="com.framework.api.stepdefinitions.TC4_DeleteUserSteps"/>
            <class name="com.framework.api.stepdefinitions.TC5_UpdateUserSteps"/>
            <class name="com.framework.api.stepdefinitions.TC6_NegativeValidationSteps"/>
        </classes>
    </test>
    
    <!-- UI Automation Tests - Run via Maven -->
    <test name="UI Automation Tests">
        <groups>
            <run>
                <include name="ui"/>
            </run>
        </groups>
        <classes>
            <class name="stepdefinitions.TC1_RegisterSteps"/>
            <class name="stepdefinitions.TC2_LoginSteps"/>
            <class name="stepdefinitions.TC3_InvalidLoginSteps"/>
            <class name="stepdefinitions.TC4_AddToCartSteps"/>
            <class name="stepdefinitions.TC5_RemoveFromCartSteps"/>
        </classes>
    </test>
    
</suite>
