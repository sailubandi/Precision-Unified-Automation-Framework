<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Hybrid Automation Test Suite" parallel="tests" thread-count="2">
    
    <!-- API Automation Tests -->
    <test name="API Automation Tests">
        <classes>
            <class name="com.framework.api.runner.ApiTestRunner"/>
        </classes>
    </test>
    
    <!-- UI Automation Tests -->
    <test name="UI Automation Tests">
        <classes>
            <class name="runner.TestRunner"/>
        </classes>
    </test>
    
</suite>
